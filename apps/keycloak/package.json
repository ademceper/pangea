{
  "name": "keycloak",
  "version": "0.0.1",
  "description": "Keycloakify theme",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build-keycloak-theme": "pnpm build && keycloakify build",
