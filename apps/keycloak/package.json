    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@pangea/ui": "workspace:*",
    "@phosphor-icons/react": "^2.1.10",
    "keycloakify": "^11.15.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@pangea/ts-cfg": "workspace:*",
    "@storybook/react": "^8.1.10",
    "@storybook/react-vite": "^8.1.10",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "postcss": "^8.4.47",
    "storybook": "^8.1.10",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^5.0.8"
  },
  "engines": {
    "node": ">=20"
  }
